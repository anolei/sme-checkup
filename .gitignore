# ──────────────────────────────────────────
# 报告输出目录（体检报告属于运行时产物，不入库）
# ──────────────────────────────────────────
reports/*
# 保留目录结构占位符
!reports/.gitkeep

# ──────────────────────────────────────────
# Python 运行时
# ──────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
*.so
*.dylib

# 虚拟环境
.venv/
venv/
env/
ENV/
.env

# ──────────────────────────────────────────
# 会话缓存 / 临时文件
# ──────────────────────────────────────────
*_session_cache.json
*_extracted.txt
*_structured.json
*.tmp
*.bak
*.swp
*.swo

# ──────────────────────────────────────────
# IDE / 编辑器
# ──────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ──────────────────────────────────────────
# WorkBuddy / Skill 工具链内部数据（不公开）
# ──────────────────────────────────────────
.workbuddy/

# ──────────────────────────────────────────
# macOS / Windows 系统文件
# ──────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
